{
    "require": {
        "php": ">=7.2",
        "graylog2/gelf-php":               "~1",
        "jumbojett/openid-connect-php":    "@stable",
        "solarium/solarium":               "@stable",
        "symfony/event-dispatcher":        "@stable",
        "phpmailer/phpmailer":             "@stable",
        "laminas/laminas-db":              "@stable",
        "laminas/laminas-paginator":       "@stable",
        "laminas/laminas-permissions-acl": "@stable"
    },
    "require-dev": {
        "phpunit/phpunit": "@stable"
    },
    "autoload": {
        "psr-4": {
            "Application\\": "src/Application",
            "Domain\\":      "src/Domain"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Test\\": "src/Test"
        }
    }
}
